// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Trade {
  id              String   @id @default(cuid())
  pair            String
  accountId       String?
  account         Account? @relation(fields: [accountId], references: [id])
  tradeType       String
  date            String
  time            String
  bias1H          String
  rangeType       String
  poiType         String
  entryPrice      String
  stopLoss        String
  takeProfit      String
  rrRatio         Float
  lotSize         String
  entryType       String
  poiTapped       Boolean?
  chochConfirmed  Boolean?
  outcome         String
  profitLoss      String
  emotion         String
  followedRules   Boolean?
  mistakes        String
  screenshots     String? // JSON stringified array of strings
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Account {
  id              String   @id @default(cuid())
  name            String
  type            String   // e.g. "funded", "personal", "demo"
  balance         Float
  accountSize     String   // e.g. "5k", "10k", "100k"
  brokerName      String   // e.g. "IC Markets", "Deriv"
  currency        String?  // e.g. "USD", "EUR"
  leverage        String?  // e.g. "1:100", "1:500"
  startDate       String?  // When the account was opened
  notes           String?  // Additional notes
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  trades          Trade[]
}
